################################################################################
# AWS Account
################################################################################

data "aws_caller_identity" "current" {}

################################################################################
# EKS
################################################################################

data "aws_eks_cluster" "cluster" {
  name = var.eks_cluster_name
}

data "aws_eks_cluster_auth" "cluster" {
  name = var.eks_cluster_name
}

################################################################################
# IAM IRSA
################################################################################

data "aws_iam_role" "manager_irsa" {
  name = var.irsa_role_name
}

################################################################################
# DynamoDB
################################################################################

data "aws_dynamodb_table" "processing" {
  name = var.dynamodb_table_name
}

################################################################################
# S3
################################################################################

data "aws_s3_bucket" "web_bucket" {
  bucket = var.s3_bucket_name
}

################################################################################
# SQS
################################################################################

data "aws_sqs_queue" "notify" {
  name = var.sqs_notify_name
}

data "aws_sqs_queue" "process" {
  name = var.sqs_process_name
}

data "aws_sqs_queue" "processed" {
  name = var.sqs_processed_name
}
